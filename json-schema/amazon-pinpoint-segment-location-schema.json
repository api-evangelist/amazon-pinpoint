{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-pinpoint/refs/heads/main/json-schema/amazon-pinpoint-segment-location-schema.json",
  "title": "SegmentLocation",
  "description": "Specifies geographical dimension settings for a segment.",
  "type": "object",
  "properties": {
    "Country": {
      "allOf": [
        {
          "$ref": "#/components/schemas/SetDimension"
        },
        {
          "description": "The country or region code, in ISO 3166-1 alpha-2 format, for the segment."
        }
      ]
    },
    "GPSPoint": {
      "allOf": [
        {
          "$ref": "#/components/schemas/GPSPointDimension"
        },
        {
          "description": "The GPS location and range for the segment."
        }
      ]
    }
  }
}