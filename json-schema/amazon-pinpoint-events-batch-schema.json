{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-pinpoint/refs/heads/main/json-schema/amazon-pinpoint-events-batch-schema.json",
  "title": "EventsBatch",
  "description": "Specifies a batch of endpoints and events to process.",
  "type": "object",
  "properties": {
    "Endpoint": {
      "allOf": [
        {
          "$ref": "#/components/schemas/PublicEndpoint"
        },
        {
          "description": "A set of properties and attributes that are associated with the endpoint."
        }
      ]
    },
    "Events": {
      "allOf": [
        {
          "$ref": "#/components/schemas/MapOfEvent"
        },
        {
          "description": "A set of properties that are associated with the event."
        }
      ]
    }
  },
  "required": [
    "Endpoint",
    "Events"
  ]
}