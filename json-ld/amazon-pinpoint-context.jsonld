{
  "@context": {
    "@vocab": "https://schema.org/",
    "pinpoint": "https://docs.aws.amazon.com/pinpoint/latest/apireference/",
    "aws": "https://aws.amazon.com/",
    "schema": "https://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "dcterms": "http://purl.org/dc/terms/",

    "Application": {
      "@id": "pinpoint:apps-application-id",
      "@context": {
        "Id": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "Arn": {
          "@id": "pinpoint:applicationArn",
          "@type": "xsd:string"
        },
        "Name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "tags": {
          "@id": "schema:keywords",
          "@container": "@index"
        },
        "CreationDate": {
          "@id": "schema:dateCreated",
          "@type": "xsd:string"
        }
      }
    },

    "Campaign": {
      "@id": "pinpoint:apps-application-id-campaigns-campaign-id",
      "@context": {
        "Id": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "ApplicationId": {
          "@id": "pinpoint:applicationId",
          "@type": "xsd:string"
        },
        "Arn": {
          "@id": "pinpoint:campaignArn",
          "@type": "xsd:string"
        },
        "Name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "Description": {
          "@id": "schema:description",
          "@type": "xsd:string"
        },
        "SegmentId": {
          "@id": "pinpoint:segmentId",
          "@type": "xsd:string"
        },
        "State": {
          "@id": "pinpoint:campaignState",
          "@type": "pinpoint:CampaignState"
        },
        "Schedule": {
          "@id": "pinpoint:schedule",
          "@type": "pinpoint:Schedule"
        },
        "MessageConfiguration": {
          "@id": "pinpoint:messageConfiguration",
          "@type": "pinpoint:MessageConfiguration"
        },
        "IsPaused": {
          "@id": "pinpoint:isPaused",
          "@type": "xsd:boolean"
        },
        "CreationDate": {
          "@id": "schema:dateCreated",
          "@type": "xsd:string"
        },
        "LastModifiedDate": {
          "@id": "schema:dateModified",
          "@type": "xsd:string"
        }
      }
    },

    "Segment": {
      "@id": "pinpoint:apps-application-id-segments-segment-id",
      "@context": {
        "Id": {
          "@id": "schema:identifier",
          "@type": "xsd:string"
        },
        "ApplicationId": {
          "@id": "pinpoint:applicationId",
          "@type": "xsd:string"
        },
        "Arn": {
          "@id": "pinpoint:segmentArn",
          "@type": "xsd:string"
        },
        "Name": {
          "@id": "schema:name",
          "@type": "xsd:string"
        },
        "SegmentType": {
          "@id": "pinpoint:segmentType",
          "@type": "xsd:string"
        },
        "CreationDate": {
          "@id": "schema:dateCreated",
          "@type": "xsd:string"
        },
        "LastModifiedDate": {
          "@id": "schema:dateModified",
          "@type": "xsd:string"
        },
        "Version": {
          "@id": "schema:version",
          "@type": "xsd:integer"
        }
      }
    },

    "Schedule": {
      "@id": "pinpoint:Schedule",
      "@context": {
        "StartTime": {
          "@id": "schema:startDate",
          "@type": "xsd:string"
        },
        "EndTime": {
          "@id": "schema:endDate",
          "@type": "xsd:string"
        },
        "Frequency": {
          "@id": "pinpoint:frequency",
          "@type": "xsd:string"
        },
        "IsLocalTime": {
          "@id": "pinpoint:isLocalTime",
          "@type": "xsd:boolean"
        },
        "Timezone": {
          "@id": "pinpoint:timezone",
          "@type": "xsd:string"
        }
      }
    }
  }
}
